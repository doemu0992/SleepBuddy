<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundleDisplayName</key>
    <string>SleepBuddy</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>SleepBuddy analysiert deine Atemgeräusche, um Schlafphasen zu erkennen. Mit deiner Erlaubnis können kurze Audioclips von Schlafgeräuschen optional in iCloud gespeichert werden.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>SleepBuddy schreibt deine Schlafdaten in Apple Health.</string>
    <key>NSHealthShareUsageDescription</key>
    <string>SleepBuddy liest Schlafdaten aus Apple Health.</string>
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
</dict>
</plist>
